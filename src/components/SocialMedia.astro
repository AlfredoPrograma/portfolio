---
import { Icon } from 'astro-icon/components';

const SOCIAL_MEDIA_LINKS = [
  {
    icon: 'lucide:github',
    url: 'https://github.com/AlfredoPrograma/',
    ariaLabel: 'navigate to github',
  },
  {
    icon: 'lucide:linkedin',
    url: 'https://www.linkedin.com/in/alfredoprograma/',
    ariaLabel: 'navigate to linkedin',
  },
  {
    icon: 'lucide:file-text',
    url: '/alfredo-arvelaez-cv-english.pdf',
    ariaLabel: 'download english curriculum',
  },
];
---

<nav class='space-x-2'>
  {
    SOCIAL_MEDIA_LINKS.map(({ icon, url, ariaLabel }) => (
      <a
        aria-label={ariaLabel}
        class='inline-block p-[6px] rounded-md text-primary transition-colors hover:text-white hover:bg-primary'
        href={url}
        target='_blank'
        rel='noopener noreferrer'
      >
        <Icon
          name={icon}
          size={24}
        />
      </a>
    ))
  }
</nav>
