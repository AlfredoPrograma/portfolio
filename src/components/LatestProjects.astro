---
import { getCollection } from 'astro:content';
import ProjectItem from './ProjectItem.astro';

const projects = await getCollection('projects');
---

<section class='space-y-4'>
  <header>
    <h3 class='text-indigo-500 font-medium text-2xl'>Latest projects</h3>
  </header>

  <div class='grid grid-cols-2 gap-8'>
    {
      projects.map(({ slug, data: { title, description, thumbnail } }) => (
        <ProjectItem
          slug={slug}
          title={title}
          description={description}
          thumbnail={{
            alt: thumbnail.alt,
            src: thumbnail.src,
          }}
        />
      ))
    }
  </div>
</section>
